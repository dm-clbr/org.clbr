# Client-side environment variables (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Standalone app URL (production)
NEXT_PUBLIC_ORG_APP_URL=https://org.clbr.com

# Optional: set only if you intentionally want cross-subdomain auth cookies.
# Leave unset for isolated host-only cookies (recommended).
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.clbr.com
